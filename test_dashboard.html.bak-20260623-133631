#view-play .play-hex-tile:nth-child(5) { --hex-size: 98px; --hex-x: 0px; --hex-y: 172px; }
#view-play .play-hex-tile:nth-child(6) { --hex-size: 96px; --hex-x: 380px; --hex-y: 172px; }
#view-play .play-hex-tile:nth-child(7) { --hex-size: 86px; --hex-x: 82px; --hex-y: 8px; opacity: 0.74; }
#view-play .play-hex-tile:nth-child(8) { --hex-size: 86px; --hex-x: 318px; --hex-y: 6px; opacity: 0.74; }

      '<div class="rs-rank mono' + rankClass + '">' + (index + 1) + '</div>' +
      '<div class="rs-avatar"><img src="' + escapeHtml(game.image) + '" alt="" loading="lazy" onerror="this.style.opacity=.18"></div>' +

const GAME_DNA_HIGHLIGHT_TITLES = ['메이플스토리', 'DARK SOULS™ III', '무기미도', 'osu!'];

function getGameScore(game) {
  let score = 0;
  if (game.isFavorite) score += 1000000000;
  if (game.yearsPlayed) score += game.yearsPlayed * 1000000;
  if (game.flag && !game.flag.includes('시간') && !game.flag.includes('년')) score += 10000000;
  if (game.isPerfectCleared) score += 1000000;
  if (game.flag && game.flag.includes('시간')) {
    const match = game.flag.match(/\d+/);
    if (match) score += parseInt(match[0], 10) * 10;
  }
  if (game.isCleared) score += 1;
  return score;
}

const GAME_SORTED_ITEMS = [...GAME_HISTORY_ITEMS].sort((a, b) => getGameScore(b) - getGameScore(a));

function gameMatchesFilter(game, filterKey) {
  if (!filterKey) return true;
  if (filterKey.startsWith('genre:')) {
    const genreLabel = filterKey.slice(6);
    const keywords = GAME_GENRE_MAP[genreLabel] || [genreLabel];
    const gameGenre = String(game.genre || '').toLowerCase();
    return keywords.some(keyword => gameGenre.includes(String(keyword).toLowerCase()));
  }
  if (filterKey === 'cleared') return Boolean(game.isCleared);
  if (filterKey === 'perfect') return Boolean(game.isPerfectCleared);
  if (filterKey === 'flagged') return Boolean(game.flag);
  if (filterKey === 'favorite') return Boolean(game.isFavorite);
  return game.category === filterKey;
}

function gameFilterCount(filterKey) {
  return GAME_SORTED_ITEMS.filter(game => gameMatchesFilter(game, filterKey)).length;
}

function escapeHtml(value) {
  return String(value ?? '').replace(/[&<>"']/g, ch => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch]));
}

function gameTags(game) {
  const tags = [];
  if (game.isFavorite) tags.push({ text: '최애', strong: true });
  if (game.isPerfectCleared) tags.push({ text: '100%', strong: true });
  else if (game.isCleared) tags.push({ text: '클리어', strong: false });
  if (game.flag) tags.push({ text: game.flag, strong: false });
  return tags.slice(0, 3);
}

function getRadarPoint(value, angleDeg, size) {
  const center = size / 2;
  const radius = (value / 100) * (size / 2 - 38);
  const rad = (angleDeg - 90) * (Math.PI / 180);
  return [center + radius * Math.cos(rad), center + radius * Math.sin(rad)];
}

function radarPoints(level, size) {
  return GAME_DNA_CHART_DATA.map(item => getRadarPoint(level ?? item.score, item.angle, size).join(',')).join(' ');
}

function toggleGameGenre(genreLabel) {
  const key = 'genre:' + genreLabel;
  setGameFilter(activeGameFilter === key ? '' : key);
}

function renderGameDnaChart() {
  const wrap = document.getElementById('game-dna-chart');
  if (!wrap) return;
  const size = 320;
  const center = size / 2;
  const activeGenre = activeGameFilter.startsWith('genre:') ? activeGameFilter.slice(6) : '';
  const bg = [20, 40, 60, 80, 100].map(level =>
    '<polygon points="' + radarPoints(level, size) + '" fill="none" stroke="rgba(244,243,238,0.12)" stroke-width="1"></polygon>'
  ).join('');
  const axes = GAME_DNA_CHART_DATA.map(item => {
    const [x, y] = getRadarPoint(100, item.angle, size);
    return '<line x1="' + center + '" y1="' + center + '" x2="' + x + '" y2="' + y + '" stroke="rgba(244,243,238,0.11)" stroke-width="1"></line>';
  }).join('');
  const dots = GAME_DNA_CHART_DATA.map(item => {
    const [x, y] = getRadarPoint(item.score, item.angle, size);
    return '<circle cx="' + x + '" cy="' + y + '" r="4" fill="var(--ice)"></circle>';
  }).join('');
  const labels = GAME_DNA_CHART_DATA.map(item => {
    const [x, y] = getRadarPoint(116, item.angle, size);
    const active = activeGenre === item.label ? ' is-active' : '';
    return '<text class="play-dna-label' + active + '" x="' + x + '" y="' + y + '" text-anchor="middle" dominant-baseline="middle" onclick="toggleGameGenre(\'' + escapeHtml(item.label) + '\')">' + escapeHtml(item.label) + '</text>';
  }).join('');
  wrap.innerHTML =
    '<svg viewBox="0 0 ' + size + ' ' + size + '" aria-hidden="true">' +
      bg +
      axes +
      '<polygon points="' + radarPoints(null, size) + '" fill="rgba(215,202,179,0.14)" stroke="var(--ice)" stroke-width="2.4"></polygon>' +
      dots +
      labels +
    '</svg>';
}

function renderGameDnaSummary() {
  const metrics = document.getElementById('game-dna-metrics');
  const highlights = document.getElementById('game-dna-highlights');
  if (metrics) {
    const pcConsole = GAME_HISTORY_ITEMS.filter(game => game.category === 'PC' || game.category === 'Console').length;
    const mobile = GAME_HISTORY_ITEMS.filter(game => game.category === 'Mobile').length;
    metrics.innerHTML = [
      { label: 'PC/Console', value: pcConsole },
      { label: 'Mobile', value: mobile }
    ].map(item => '<div class="play-dna-metric"><strong class="mono">' + item.value + '</strong><span>' + item.label + '</span></div>').join('');
  }
  if (highlights) {
    const items = GAME_DNA_HIGHLIGHT_TITLES
      .map(title => GAME_HISTORY_ITEMS.find(g => g.title === title))
      .filter(Boolean);
    highlights.innerHTML = items.map(game => {
      const sub = [game.genre, game.flag].filter(Boolean).join(' · ');
      return '<div class="play-dna-highlight">' +
        '<div class="play-dna-thumb"><img src="' + escapeHtml(game.image) + '" alt="" loading="lazy" onerror="this.style.opacity=.18"></div>' +
        '<div><div class="play-dna-name">' + escapeHtml(game.title) + '</div>' +
        '<div class="play-dna-sub">' + escapeHtml(sub) + '</div></div>' +
      '</div>';
    }).join('');
  }
}

function renderGameFilters() {
  const wrap = document.getElementById('game-filter-tabs');

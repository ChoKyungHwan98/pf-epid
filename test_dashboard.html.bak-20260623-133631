      '<div class="rs-year mono">' + escapeHtml(game.category) + '</div>' +
    '</div>';
  }).join('');
}

function renderGameList() {
  const list = document.getElementById('game-list');
  const counter = document.getElementById('game-filter-count');
  if (!list) return;
  const filtered = GAME_SORTED_ITEMS.filter(game => gameMatchesFilter(game, activeGameFilter));
  if (counter) counter.innerHTML = '<span class="mono">' + filtered.length + '</span><span class="count-unit">개</span>';
  list.innerHTML = filtered.map(game => {
    const tags = gameTags(game).map(tag => '<span class="game-op-tag' + (tag.strong ? ' is-strong' : '') + '">' + escapeHtml(tag.text) + '</span>').join('');
    return '<article class="game-op-card" data-category="' + escapeHtml(game.category) + '">' +
      '<div class="game-op-cover"><img src="' + escapeHtml(game.image) + '" alt="' + escapeHtml(game.title) + '" loading="lazy" onerror="this.style.opacity=.18"></div>' +
      '<div class="game-op-body">' +
        '<div class="game-op-title">' + escapeHtml(game.title) + '</div>' +
        '<div class="game-op-meta"><span>' + escapeHtml(game.genre) + '</span><span>' + escapeHtml(game.category) + '</span></div>' +
        '<div class="game-op-tags">' + tags + '</div>' +
      '</div>' +
    '</article>';
  }).join('');
}

function setGameFilter(filterKey) {
  activeGameFilter = filterKey;
  renderGameFilters();
  renderGameDnaChart();
  renderGameList();
}

function initGameHistory() {
  renderGameHex();
  renderFavoriteGames();
  renderGameDnaChart();
  renderGameDnaSummary();
  renderPortfolioTabs();
  renderPortfolioGrid();
  renderGameFilters();
  renderGameList();
}
